generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  phoneOrEmail    String   @unique
  role            String   // LANDLORD | TENANT
  passwordHash    String?
  themePreference String   @default("DARK") // LIGHT | DARK | SYSTEM
  plan            String   @default("FREE") // FREE | PRO
  createdAt       DateTime @default(now())

  // Landlord relations
  ownedProperties   Property[]       @relation("LandlordProperties")
  landlordTenancies Tenancy[]        @relation("LandlordTenancies")
  landlordPayments  Payment[]        @relation("LandlordPayments")
  landlordInvites   Invite[]         @relation("LandlordInvites")
  landlordDisputes  Dispute[]        @relation("LandlordDisputes")
  upgradeRequests   UpgradeRequest[]

  // Tenant relations
  tenantTenancies Tenancy[] @relation("TenantTenancies")
  tenantPayments  Payment[] @relation("TenantPayments")
  tenantDisputes  Dispute[] @relation("TenantDisputes")

  notifications Notification[]

  @@index([phoneOrEmail])
  @@index([role])
}

model Property {
  id          String   @id @default(cuid())
  landlordId  String
  label       String
  area        String   @default("")
  defaultRent Float    @default(0)
  dueDay      Int      @default(1)
  currency    String   @default("ZMW")
  createdAt   DateTime @default(now())

  landlord  User      @relation("LandlordProperties", fields: [landlordId], references: [id])
  units     Unit[]
  tenancies Tenancy[]
  payments  Payment[]
  invites   Invite[]
  disputes  Dispute[]

  @@index([landlordId])
}

model Unit {
  id              String   @id @default(cuid())
  propertyId      String
  label           String
  rentOverride    Float?
  occupancyStatus String   @default("VACANT") // VACANT | OCCUPIED
  createdAt       DateTime @default(now())

  property  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancies Tenancy[]
  payments  Payment[]
  invites   Invite[]
  disputes  Dispute[]

  @@index([propertyId])
  @@index([occupancyStatus])
}

model Tenancy {
  id           String   @id @default(cuid())
  tenantId     String
  landlordId   String
  propertyId   String
  unitId       String
  leaseStart   DateTime
  leaseEnd     DateTime
  monthlyRent  Float
  dueDay       Int
  currency     String   @default("ZMW")
  balanceOwing Float    @default(0)
  status       String   @default("PENDING") // ACTIVE | ENDED | EXPIRED | PENDING
  createdAt    DateTime @default(now())

  tenant   User     @relation("TenantTenancies", fields: [tenantId], references: [id])
  landlord User     @relation("LandlordTenancies", fields: [landlordId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit     @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@index([unitId])
}

model Invite {
  id         String    @id @default(cuid())
  landlordId String
  propertyId String
  unitId     String?
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  landlord User     @relation("LandlordInvites", fields: [landlordId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit?    @relation(fields: [unitId], references: [id])

  @@index([token])
  @@index([landlordId])
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  landlordId    String
  propertyId    String
  unitId        String
  amount        Float
  currency      String   @default("ZMW")
  method        String
  referenceNote String?
  paidOn        DateTime
  status        String   @default("PENDING") // PENDING | CONFIRMED | DISPUTED
  createdAt     DateTime @default(now())

  tenant   User     @relation("TenantPayments", fields: [tenantId], references: [id])
  landlord User     @relation("LandlordPayments", fields: [landlordId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit     @relation(fields: [unitId], references: [id])
  receipt  Receipt?

  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@index([paidOn])
}

model Receipt {
  id            String    @id @default(cuid())
  paymentId     String    @unique
  receiptNumber String    @unique
  publicToken   String?
  status        String    @default("ISSUED") // ISSUED | CONFIRMED | DISPUTED
  confirmedAt   DateTime?
  disputeNote   String?
  createdAt     DateTime  @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([receiptNumber])
  @@index([publicToken])
}

model Dispute {
  id             String   @id @default(cuid())
  tenantId       String
  landlordId     String
  propertyId     String
  unitId         String
  paymentId      String?
  receiptId      String?
  title          String
  description    String
  status         String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  resolutionNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   User     @relation("TenantDisputes", fields: [tenantId], references: [id])
  landlord User     @relation("LandlordDisputes", fields: [landlordId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  unit     Unit     @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
}

model UpgradeRequest {
  id            String   @id @default(cuid())
  landlordId    String
  requestedPlan String   // FREE | PRO
  referenceText String
  note          String?
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime @default(now())

  landlord User @relation(fields: [landlordId], references: [id])

  @@index([landlordId])
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  channel     String   @default("WHATSAPP") // WHATSAPP | EMAIL
  event       String   // OTP_SENT | INVITE_CREATED | PAYMENT_LOGGED | etc.
  status      String   @default("PENDING") // PENDING | SENT | FAILED | SKIPPED
  messageId   String?
  error       String?
  metadata    String?  // JSON: { template, params }
  createdAt   DateTime @default(now())

  recipient User @relation(fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([createdAt])
}

model OtpCode {
  id         String    @id @default(cuid())
  identifier String
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier, code])
  @@index([expiresAt])
}
